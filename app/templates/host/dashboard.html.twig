{% extends 'host/_layout.html.twig' %}

{% block title %}Host dashboard - {% endblock %}

{% block host_content %}

    {% set rooms = [
        { id: 1, name: 'Boardroom Alpha', city: 'Financial District', capacity: 12, price: 45, status: 'published', image: 'gen_94e366db06_18eb67896de2eba2.png' },
        { id: 2, name: 'Creative Studio Hub', city: 'SoMa', capacity: 6, price: 30, status: 'published', image: 'gen_7747ab4caa_2d084ba9936cb701.png' },
        { id: 3, name: 'Focus Pod 02', city: 'Mission District', capacity: 2, price: 15, status: 'draft', image: 'gen_2e06e95900_3a246ce11c91d2b7.png' },
    ] %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold text-app mb-0" style="font-size: 1.5rem;">My rooms</h1>
        <a href="{{ path('app_host_room_new') }}" class="btn-signup">
            <i class="fa-solid fa-plus me-2"></i> Add a room
        </a>
    </div>

    <div class="row row-cols-1 row-cols-sm-3 g-3 mb-4">
        <div class="col">
            <div class="feature-card bg-white p-3">
                <div class="text-muted-app" style="font-size: 0.875rem;">Total rooms</div>
                <div class="fw-bold text-app fs-3">{{ rooms|length }}</div>
            </div>
        </div>
        <div class="col">
            <div class="feature-card bg-white p-3">
                <div class="text-muted-app" style="font-size: 0.875rem;">Published</div>
                <div class="fw-bold text-app fs-3">{{ rooms|filter(r => r.status == 'published')|length }}</div>
            </div>
        </div>
        <div class="col">
            <div class="feature-card bg-white p-3">
                <div class="text-muted-app" style="font-size: 0.875rem;">Draft</div>
                <div class="fw-bold text-app fs-3">{{ rooms|filter(r => r.status == 'draft')|length }}</div>
            </div>
        </div>
    </div>

    <div class="row row-cols-1 row-cols-md-2 g-3 g-lg-4">
        {% for room in rooms %}
            <div class="col">
                <div class="room-card d-flex flex-column h-100">
                    <div class="img-wrap">
                        <img src="{{ asset('images/' ~ room.image) }}" alt="{{ room.name }}">
                        <div class="badge-avail" style="{{ room.status == 'draft' ? 'background-color: rgba(245, 158, 11, 0.12); color: var(--c-warning);' : '' }}">
                            {{ room.status == 'published' ? 'Published' : 'Draft' }}
                        </div>
                    </div>
                    <div class="p-3 d-flex flex-column flex-grow-1">
                        <div class="text-uppercase fw-medium mb-1 text-muted-app tracking-wider" style="font-size: 11px;">
                            {{ room.city }}
                        </div>
                        <h3 class="fw-semibold fs-6 text-app mb-2 line-clamp-1">{{ room.name }}</h3>
                        <div class="d-flex align-items-center gap-3 mt-auto pt-2 text-muted-app" style="font-size: 0.875rem;">
                            <span class="d-flex align-items-center gap-2">
                                <i class="fa-solid fa-user-group"></i> {{ room.capacity }}
                            </span>
                            <span class="d-flex align-items-center gap-2">
                                <i class="fa-solid fa-tag"></i> ${{ room.price }}/hr
                            </span>
                        </div>

                        <div class="pt-3 mt-3 border-top border-app d-flex flex-wrap gap-2">
                            <a href="{{ path('app_host_room_edit', { id: room.id }) }}" class="btn-book">
                                <i class="fa-solid fa-pen me-1"></i> Edit
                            </a>
                            <a href="{{ path('app_host_room_gallery', { id: room.id }) }}" class="btn-book">
                                <i class="fa-solid fa-images me-1"></i> Gallery
                            </a>
                            <a href="{{ path('app_host_room_amenities', { id: room.id }) }}" class="btn-book">
                                <i class="fa-solid fa-plug me-1"></i> Amenities
                            </a>
                            <a href="{{ path('app_host_room_status', { id: room.id }) }}" class="btn-book">
                                <i class="fa-solid fa-toggle-on me-1"></i> Status
                            </a>
                            <a href="{{ path('app_host_room_delete', { id: room.id }) }}" class="btn-book" style="color: var(--c-danger); background-color: rgba(239, 68, 68, 0.08);">
                                <i class="fa-solid fa-trash me-1"></i> Delete
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>

{% endblock %}
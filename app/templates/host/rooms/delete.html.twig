{% extends 'host/_layout.html.twig' %}

{% block title %}Delete room - {% endblock %}

{% block host_content %}

    <div class="bg-white p-4 text-center" style="border: 1px solid var(--c-border); border-radius: var(--radius-md); max-width: 480px;">
        <div class="d-flex align-items-center justify-content-center mx-auto mb-3 rounded-circle"
             style="width: 56px; height: 56px; background-color: rgba(239, 68, 68, 0.1);">
            <i class="fa-solid fa-trash" style="color: var(--c-danger);"></i>
        </div>

        <h1 class="fw-bold text-app mb-2" style="font-size: 1.25rem;">Delete room #{{ id }}?</h1>
        <p class="text-muted-app mb-4">
            This action cannot be undone. The room and its associated photos will be permanently removed from your listings.
        </p>

        <form method="post" class="d-flex justify-content-center gap-2">
            <button type="submit" class="btn-signup" style="background-color: var(--c-danger);">
                <i class="fa-solid fa-trash me-2"></i> Delete room
            </button>
            <a href="{{ path('app_host_dashboard') }}" class="btn-login">Cancel</a>
        </form>
    </div>

{% endblock %}
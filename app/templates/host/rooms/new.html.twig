{% extends 'host/_layout.html.twig' %}

{% block title %}Add a room - {% endblock %}

{% block host_content %}

    <div class="d-flex align-items-center gap-2 mb-4">
        <a href="{{ path('app_host_dashboard') }}" class="text-muted-app text-decoration-none">
            <i class="fa-solid fa-arrow-left"></i>
        </a>
        <h1 class="fw-bold text-app mb-0" style="font-size: 1.5rem;">Add a room</h1>
    </div>

    <div class="bg-white p-4" style="border: 1px solid var(--c-border); border-radius: var(--radius-md); max-width: 720px;">
        <form method="post">
            <div class="mb-3">
                <label class="form-label text-app fw-medium">Room name</label>
                <input type="text" name="name" class="form-control" placeholder="Boardroom Alpha">
            </div>

            <div class="mb-3">
                <label class="form-label text-app fw-medium">Description</label>
                <textarea name="description" class="form-control" rows="4" placeholder="Describe the space, its atmosphere and what makes it unique."></textarea>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-6">
                    <label class="form-label text-app fw-medium">Capacity</label>
                    <input type="number" name="capacity" class="form-control" min="1" placeholder="12">
                </div>
                <div class="col-6">
                    <label class="form-label text-app fw-medium">Hourly price ($)</label>
                    <input type="number" name="hourly_price" class="form-control" min="0" step="0.01" placeholder="45">
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label text-app fw-medium">Address</label>
                <input type="text" name="address" class="form-control" placeholder="123 Market Street">
            </div>

            <div class="row g-3 mb-4">
                <div class="col-8">
                    <label class="form-label text-app fw-medium">City</label>
                    <input type="text" name="city" class="form-control" placeholder="San Francisco">
                </div>
                <div class="col-4">
                    <label class="form-label text-app fw-medium">Postal code</label>
                    <input type="text" name="postal_code" class="form-control" placeholder="94105">
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn-signup">Create room</button>
                <a href="{{ path('app_host_dashboard') }}" class="btn-login">Cancel</a>
            </div>
        </form>
    </div>

{% endblock %}
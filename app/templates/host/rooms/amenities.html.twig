{% extends 'host/_layout.html.twig' %}

{% block title %}Room amenities - {% endblock %}

{% block host_content %}

    {% set amenities = [
        { name: 'Wi-Fi', icon: 'fa-wifi', checked: true },
        { name: 'Screen / TV', icon: 'fa-tv', checked: true },
        { name: 'Whiteboard', icon: 'fa-chalkboard', checked: false },
        { name: 'Coffee', icon: 'fa-mug-hot', checked: true },
        { name: 'Air conditioning', icon: 'fa-wind', checked: false },
        { name: 'A/V setup', icon: 'fa-microphone', checked: false },
    ] %}

    <div class="d-flex align-items-center gap-2 mb-4">
        <a href="{{ path('app_host_dashboard') }}" class="text-muted-app text-decoration-none">
            <i class="fa-solid fa-arrow-left"></i>
        </a>
        <h1 class="fw-bold text-app mb-0" style="font-size: 1.5rem;">Amenities — room #{{ id }}</h1>
    </div>

    <div class="bg-white p-4" style="border: 1px solid var(--c-border); border-radius: var(--radius-md); max-width: 640px;">
        <form method="post">
            <div class="row row-cols-1 row-cols-sm-2 g-3 mb-4">
                {% for amenity in amenities %}
                    <div class="col">
                        <label class="d-flex align-items-center gap-3 p-3" style="border: 1px solid var(--c-border); border-radius: var(--radius-md); cursor: pointer;">
                            <input type="checkbox" name="amenities[]" value="{{ amenity.name }}" {{ amenity.checked ? 'checked' : '' }}>
                            <i class="fa-solid {{ amenity.icon }} text-muted-app"></i>
                            <span class="text-app">{{ amenity.name }}</span>
                        </label>
                    </div>
                {% endfor %}
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn-signup">Save amenities</button>
                <a href="{{ path('app_host_dashboard') }}" class="btn-login">Cancel</a>
            </div>
        </form>
    </div>

{% endblock %}
{% extends 'base.html.twig' %}

{% block title %}Forgot password{% endblock %}

{% block body_class %}lost-password-page{% endblock %}

{% block body %}
    <section class="auth-section py-5">
        <div class="container-xl px-4">
            <div class="row justify-content-center">
                <div class="col-12 col-md-10 col-lg-7 col-xl-5">
                    <div class="auth-card p-4 p-md-5">
                        <div class="mb-4 text-center">
                            <span class="auth-badge mb-3">
                                <i class="fa-solid fa-key"></i>
                                Password recovery
                            </span>
                            <h1 class="fw-bold text-app mb-2" style="font-size: clamp(2rem, 4vw, 2.75rem); line-height: 1.1;">
                                Forgot your password?
                            </h1>
                            <p class="text-muted-app mb-0" style="font-size: 1rem;">
                                Enter the email address linked to your account and we'll send you a link to reset your password.
                            </p>
                        </div>

                        {% for flash_success in app.flashes('reset_password_success') %}
                            <div class="alert alert-success" role="alert">{{ flash_success }}</div>
                        {% endfor %}

                        {{ form_start(form) }}
                        {{ form_errors(form) }}

                        <div class="mb-4">
                            {{ form_label(form.email, 'Email address', {'label_attr': {'class': 'form-label form-label-custom'}}) }}
                            <div class="input-icon-wrap">
                                <i class="fa-regular fa-envelope input-icon"></i>
                                {{ form_widget(form.email) }}
                            </div>

                            {{ form_errors(form.email) }}
                        </div>

                        <button type="submit" class="btn btn-auth-primary w-100 mb-4">
                            Send reset link
                        </button>

                        <p class="text-center text-muted-app mb-0" style="font-size: 0.95rem;">
                            Remembered your password?
                            <a href="{{ path('app_login') }}" class="text-primary-app text-decoration-none fw-semibold">Log in</a>
                        </p>

                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Reset password{% endblock %}

{% block body_class %}reset-password-page{% endblock %}

{% block body %}
    <section class="auth-section py-5">
        <div class="container-xl px-4">
            <div class="row justify-content-center">
                <div class="col-12 col-md-10 col-lg-7 col-xl-5">
                    <div class="auth-card p-4 p-md-5">
                        <div class="mb-4 text-center">
                            <span class="auth-badge mb-3">
                                <i class="fa-solid fa-lock"></i>
                                Update password
                            </span>
                            <h1 class="fw-bold text-app mb-2" style="font-size: clamp(2rem, 4vw, 2.75rem); line-height: 1.1;">
                                Reset your password
                            </h1>
                            <p class="text-muted-app mb-0" style="font-size: 1rem;">
                                Choose a strong new password to keep your account secure.
                            </p>
                        </div>

                        {% for flash_error in app.flashes('reset_password_error') %}
                            <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
                        {% endfor %}

                        {{ form_start(form) }}
                        {{ form_errors(form) }}

                        <div class="mb-3">
                            {{ form_label(form.newPassword, null, {'label_attr': {'class': 'form-label form-label-custom'}}) }}
                            <div class="input-icon-wrap">
                                <i class="fa-solid fa-key input-icon"></i>
                                {{ form_widget(form.newPassword) }}
                            </div>

                            {{ form_errors(form.newPassword) }}
                        </div>

                        <div class="mb-4">
                            {{ form_label(form.confirmPassword, null, {'label_attr': {'class': 'form-label form-label-custom'}}) }}
                            <div class="input-icon-wrap">
                                <i class="fa-solid fa-key input-icon"></i>
                                {{ form_widget(form.confirmPassword) }}
                            </div>
                            {{ form_errors(form.confirmPassword) }}
                        </div>

                        <button type="submit" class="btn btn-auth-primary w-100 mb-4">
                            Update password
                        </button>

                        <p class="text-center text-muted-app mb-0" style="font-size: 0.95rem;">
                            Changed your mind?
                            <a href="{{ path('app_login') }}" class="text-primary-app text-decoration-none fw-semibold">Back to login</a>
                        </p>

                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Homepage{% endblock %}

{% block body %}

    <main class="flex-grow-1" style="padding-top: 80px;">

        <!-- Hero Section -->
        <section id="hero" class="position-relative overflow-hidden bg-white border-bottom border-app"
                 style="padding-top: 6rem; padding-bottom: 8rem;">
            <div class="container position-relative" style="max-width: 960px; z-index: 10;">
                <div class="text-center">
                    <h1 class="fw-bold tracking-tight text-app mb-4"
                        style="font-size: clamp(2rem, 5vw, 3.75rem); line-height: 1.1;">
                        Book local meeting rooms
                        <br class="d-none d-md-block">
                        and collaborative workspaces.
                    </h1>
                    <p class="text-muted-app fs-5 mx-auto mb-5" style="max-width: 640px;">
                        Discover, book, and manage premium spaces for your team in seconds. No commitments, just great places to work.
                    </p>

                    <!-- Search Bar -->
                    <div class="search-bar p-2 mx-auto" style="max-width: 880px; z-index: 20; position: relative;">
                        <div class="d-flex flex-column flex-md-row align-items-stretch">

                            <!-- Location -->
                            <div class="search-field d-flex align-items-center px-3 py-2 flex-grow-1 rounded-top"
                                 style="cursor: text;">
                                <i class="fa-solid fa-location-dot text-muted-app me-3"></i>
                                <div class="text-start w-100">
                                    <label>Location</label>
                                    <input type="text" placeholder="City, neighborhood, or building" value="San Francisco, CA">
                                </div>
                            </div>

                            <!-- Date -->
                            <div class="search-field d-flex align-items-center px-3 py-2 flex-grow-1">
                                <i class="fa-regular fa-calendar text-muted-app me-3"></i>
                                <div class="text-start w-100">
                                    <label>Date</label>
                                    <div class="fw-medium text-app" style="font-size: 0.875rem;">Oct 24, 2023</div>
                                </div>
                            </div>

                            <!-- Time -->
                            <div class="search-field d-flex align-items-center px-3 py-2 flex-grow-1">
                                <i class="fa-regular fa-clock text-muted-app me-3"></i>
                                <div class="text-start w-100">
                                    <label>Time</label>
                                    <div class="fw-medium text-app" style="font-size: 0.875rem;">09:00 AM - 2 hrs</div>
                                </div>
                            </div>

                            <!-- Capacity (no right border) -->
                            <div class="search-field search-field-last d-flex align-items-center px-3 py-2 flex-grow-1">
                                <i class="fa-solid fa-user-group text-muted-app me-3"></i>
                                <div class="text-start w-100">
                                    <label>Capacity</label>
                                    <div class="fw-medium text-app" style="font-size: 0.875rem;">Up to 8 people</div>
                                </div>
                            </div>

                            <!-- Search Button -->
                            <div class="ps-2 pe-1 py-1 d-flex align-items-stretch">
                                <button class="search-btn">Search</button>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 d-flex align-items-center justify-content-center gap-4 text-muted-app"
                         style="font-size: 0.875rem;">
                        <span class="d-flex align-items-center gap-2">
                            <i class="fa-solid fa-check-circle text-success-app"></i> Instant booking
                        </span>
                        <span class="d-flex align-items-center gap-2">
                            <i class="fa-solid fa-check-circle text-success-app"></i> Verified spaces
                        </span>
                    </div>
                </div>
            </div>
        </section>

        <!-- Features Section -->
        <section id="features" class="section-py" style="background-color: var(--c-appbg);">
            <div class="container-xl px-4">
                <div class="text-center mx-auto mb-5" style="max-width: 720px;">
                    <h2 class="fw-bold text-app" style="font-size: 1.875rem;">
                        Everything you need to work effectively
                    </h2>
                    <p class="mt-3 text-muted-app fs-5 mb-0">
                        Designed for modern teams who value flexibility and premium environments.
                    </p>
                </div>

                <div class="row row-cols-1 row-cols-md-3 g-4 g-lg-5">

                    <!-- Feature 1 -->
                    <div class="col">
                        <div class="feature-card bg-white p-4 p-lg-5 h-100 shadow-sm">
                            <div class="feature-icon mb-4" style="background-color: var(--c-accent); color: var(--c-primary);">
                                <i class="fa-solid fa-bolt"></i>
                            </div>
                            <h3 class="fw-semibold fs-5 text-app mb-3">Easy booking</h3>
                            <p class="text-muted-app leading-relaxed mb-0">
                                Find and reserve a space in less than 60 seconds. Our intuitive interface makes scheduling a breeze for you
                                and your team.
                            </p>
                        </div>
                    </div>

                    <!-- Feature 2 -->
                    <div class="col">
                        <div class="feature-card bg-white p-4 p-lg-5 h-100 shadow-sm">
                            <div class="feature-icon mb-4" style="background-color: rgba(67, 122, 34, 0.12); color: var(--c-success);">
                                <i class="fa-regular fa-clock"></i>
                            </div>
                            <h3 class="fw-semibold fs-5 text-app mb-3">Real-time availability</h3>
                            <p class="text-muted-app leading-relaxed mb-0">
                                Say goodbye to double bookings. Our calendar syncs instantly, showing you exactly what spaces are open right
                                now.
                            </p>
                        </div>
                    </div>

                    <!-- Feature 3 -->
                    <div class="col">
                        <div class="feature-card bg-white p-4 p-lg-5 h-100 shadow-sm">
                            <div class="feature-icon mb-4" style="background-color: rgba(31, 41, 55, 0.06); color: var(--c-text);">
                                <i class="fa-solid fa-shield-halved"></i>
                            </div>
                            <h3 class="fw-semibold fs-5 text-app mb-3">Secure reservations</h3>
                            <p class="text-muted-app leading-relaxed mb-0">
                                Enterprise-grade security for your payments and data. Manage access control directly through our unified
                                dashboard.
                            </p>
                        </div>
                    </div>

                </div>
            </div>
        </section>

        <!-- Popular Rooms Section -->
        <section id="popular-rooms" class="section-py bg-white border-top border-app">
            <div class="container-xl px-4">
                <div class="d-flex justify-content-between align-items-end mb-4 mb-lg-5">
                    <div>
                        <h2 class="fw-bold text-app mb-2" style="font-size: 1.875rem;">
                            Popular spaces in San Francisco
                        </h2>
                        <p class="text-muted-app mb-0">
                            Highly rated meeting rooms and private offices available today.
                        </p>
                    </div>
                    <a href="#" class="d-none d-sm-flex align-items-center fw-medium text-primary-app"
                       style="text-decoration: none;">
                        View all <i class="fa-solid fa-arrow-right ms-2" style="font-size: 0.875rem;"></i>
                    </a>
                </div>

                <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-3 g-lg-4">

                    <!-- Card 1 -->
                    <div class="col">
                        <div class="room-card d-flex flex-column h-100">
                            <div class="img-wrap">
                                <img src="https://storage.googleapis.com/uxpilot-auth.appspot.com/gen_94e366db06_18eb67896de2eba2.png"
                                     alt="modern bright corporate meeting room with large glass windows and wooden table">
                                <div class="badge-rating">
                                    <i class="fa-solid fa-star me-1 text-warning-app" style="font-size: 10px;"></i> 4.9 (128)
                                </div>
                                <div class="badge-avail">Available now</div>
                            </div>
                            <div class="p-3 d-flex flex-column flex-grow-1">
                                <div class="text-uppercase fw-medium mb-1 text-muted-app tracking-wider"
                                     style="font-size: 11px;">Financial District
                                </div>
                                <h3 class="fw-semibold fs-6 text-app mb-2 line-clamp-1">Boardroom Alpha</h3>
                                <div class="d-flex align-items-center gap-3 mt-auto pt-2 text-muted-app"
                                     style="font-size: 0.875rem;">
                                    <span class="d-flex align-items-center gap-2">
                                        <i class="fa-solid fa-user-group"></i> 12
                                    </span>
                                    <span class="d-flex align-items-center gap-2">
                                        <i class="fa-solid fa-tv"></i> Screen
                                    </span>
                                </div>
                                <div class="pt-3 mt-3 border-top border-app d-flex justify-content-between align-items-center">
                                    <div>
                                        <span class="fw-bold fs-5 text-app">$45</span>
                                        <span class="text-muted-app" style="font-size: 0.875rem;">/hr</span>
                                    </div>
                                    <button class="btn-book">Book</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Card 2 -->
                    <div class="col">
                        <div class="room-card d-flex flex-column h-100">
                            <div class="img-wrap">
                                <img src="https://storage.googleapis.com/uxpilot-auth.appspot.com/gen_7747ab4caa_2d084ba9936cb701.png"
                                     alt="cozy creative workspace with plants and colorful furniture">
                                <div class="badge-rating">
                                    <i class="fa-solid fa-star me-1 text-warning-app" style="font-size: 10px;"></i> 4.8 (84)
                                </div>
                            </div>
                            <div class="p-3 d-flex flex-column flex-grow-1">
                                <div class="text-uppercase fw-medium mb-1 text-muted-app tracking-wider"
                                     style="font-size: 11px;">SoMa
                                </div>
                                <h3 class="fw-semibold fs-6 text-app mb-2 line-clamp-1">Creative Studio Hub</h3>
                                <div class="d-flex align-items-center gap-3 mt-auto pt-2 text-muted-app"
                                     style="font-size: 0.875rem;">
                                    <span class="d-flex align-items-center gap-2">
                                        <i class="fa-solid fa-user-group"></i> 6
                                    </span>
                                    <span class="d-flex align-items-center gap-2">
                                        <i class="fa-solid fa-mug-hot"></i> Coffee
                                    </span>
                                </div>
                                <div class="pt-3 mt-3 border-top border-app d-flex justify-content-between align-items-center">
                                    <div>
                                        <span class="fw-bold fs-5 text-app">$30</span>
                                        <span class="text-muted-app" style="font-size: 0.875rem;">/hr</span>
                                    </div>
                                    <button class="btn-book">Book</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Card 3 -->
                    <div class="col">
                        <div class="room-card d-flex flex-column h-100">
                            <div class="img-wrap">
                                <img src="https://storage.googleapis.com/uxpilot-auth.appspot.com/gen_2e06e95900_3a246ce11c91d2b7.png"
                                     alt="minimalist private glass office pod in a large open space">
                                <div class="badge-rating">
                                    <i class="fa-solid fa-star me-1 text-warning-app" style="font-size: 10px;"></i> 5.0 (42)
                                </div>
                                <div class="badge-avail">Available now</div>
                            </div>
                            <div class="p-3 d-flex flex-column flex-grow-1">
                                <div class="text-uppercase fw-medium mb-1 text-muted-app tracking-wider"
                                     style="font-size: 11px;">Mission District
                                </div>
                                <h3 class="fw-semibold fs-6 text-app mb-2 line-clamp-1">Focus Pod 02</h3>
                                <div class="d-flex align-items-center gap-3 mt-auto pt-2 text-muted-app"
                                     style="font-size: 0.875rem;">
                                    <span class="d-flex align-items-center gap-2">
                                        <i class="fa-solid fa-user-group"></i> 2
                                    </span>
                                    <span class="d-flex align-items-center gap-2">
                                        <i class="fa-solid fa-wifi"></i> Fast Wi-Fi
                                    </span>
                                </div>
                                <div class="pt-3 mt-3 border-top border-app d-flex justify-content-between align-items-center">
                                    <div>
                                        <span class="fw-bold fs-5 text-app">$15</span>
                                        <span class="text-muted-app" style="font-size: 0.875rem;">/hr</span>
                                    </div>
                                    <button class="btn-book">Book</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Card 4 -->
                    <div class="col">
                        <div class="room-card d-flex flex-column h-100">
                            <div class="img-wrap">
                                <img src="https://storage.googleapis.com/uxpilot-auth.appspot.com/gen_308f55bfb1_62531061c747d2ce.png"
                                     alt="large modern event space with theater seating and a stage">
                                <div class="badge-rating">
                                    <i class="fa-solid fa-star me-1 text-warning-app" style="font-size: 10px;"></i> 4.7 (215)
                                </div>
                            </div>
                            <div class="p-3 d-flex flex-column flex-grow-1">
                                <div class="text-uppercase fw-medium mb-1 text-muted-app tracking-wider"
                                     style="font-size: 11px;">Downtown
                                </div>
                                <h3 class="fw-semibold fs-6 text-app mb-2 line-clamp-1">The Grand Assembly</h3>
                                <div class="d-flex align-items-center gap-3 mt-auto pt-2 text-muted-app"
                                     style="font-size: 0.875rem;">
                                    <span class="d-flex align-items-center gap-2">
                                        <i class="fa-solid fa-user-group"></i> 50+
                                    </span>
                                    <span class="d-flex align-items-center gap-2">
                                        <i class="fa-solid fa-microphone"></i> A/V Setup
                                    </span>
                                </div>
                                <div class="pt-3 mt-3 border-top border-app d-flex justify-content-between align-items-center">
                                    <div>
                                        <span class="fw-bold fs-5 text-app">$150</span>
                                        <span class="text-muted-app" style="font-size: 0.875rem;">/hr</span>
                                    </div>
                                    <button class="btn-book">Book</button>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>

                <!-- Mobile "View all" button -->
                <div class="mt-4 text-center d-sm-none">
                    <button class="btn w-100 fw-medium text-app"
                            style="border: 1px solid var(--c-border); border-radius: var(--radius-md); padding: 12px;">
                        View all spaces
                    </button>
                </div>
            </div>
        </section>

    </main>

{% endblock %}
